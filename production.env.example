# ClawGuard production env
CLAWGUARD_LISTEN=:18080
CLAWGUARD_AUDIT_PATH=/var/log/clawguard/audit.log
CLAWGUARD_TOKEN=replace-with-strong-random-token
CLAWGUARD_MODEL_TARGET=http://127.0.0.1:8080/model

# policy actions: ALLOW_REDACTED | BLOCK | LOCAL_ONLY
CLAWGUARD_DEFAULT_ACTION=ALLOW_REDACTED
CLAWGUARD_HIGH_ACTION=BLOCK
